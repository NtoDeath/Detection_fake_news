{"triple_norm": ["monroe", "open a law office in", "fredericksburg"], "true_link": {"object": "/m/0mnwd", "subject": "/m/042d1"}, "src_sentences": ["Monroe open a law office in Fredericksburg", "Monroe opened a law office in Fredericksburg, and he and his wife Elizabeth moved there in November 1786, after his three-year term in the Congress of the Confederation expired.", "The Monroes moved to the Charlottesville area from Fredericksburg in August, 1789 (Cunningham 1996: 2-3).", "The James Monroe Museum stands today at 908 Charles Street, on part of the property Monroe owned in Fredericksburg."], "triple": ["Monroe", "open a law office in", "Fredericksburg"], "kbp_info": [["ORGANIZATION", "per:cities_of_residence", "CITY"], ["ORGANIZATION", "per:cities_of_residence", "CITY"]], "entity_linking": {"object": "Fredericksburg,_Virginia", "subject": null}, "_id": 4124}
